# Django
SECRET_KEY=your-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database — Dockerized PostgreSQL via docker-compose.yml in this directory.
# Host port 5434 is used by default to avoid clashing with any local PostgreSQL.
POSTGRES_USER=arbitration_art
POSTGRES_PASSWORD=arbitration_art_dev_pass
POSTGRES_DB=arbitration_art
POSTGRES_HOST_PORT=5434
DATABASE_URL=postgres://arbitration_art:arbitration_art_dev_pass@localhost:5434/arbitration_art

# Internationalization
LANGUAGE_CODE=ru
TIME_ZONE=Asia/Almaty

# CORS (production only)
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# CSRF trusted origins (production only). Required for admin/login POST when
# Django is behind a TLS-terminating reverse proxy (Dokploy / Traefik).
# Must include scheme, comma-separated, no trailing slash.
# CSRF_TRUSTED_ORIGINS=https://art-api.jscode.kz,https://your-frontend-domain.com

# Security (production only)
# SECURE_SSL_REDIRECT=True

# Service-to-service auth / control plane
SERVICE_SHARED_TOKEN=change-me-service-token
# Default service_url for new BotConfig. Engine uses ENGINE_SERVICE_URL on its
# side to fetch active bots from /api/bots/engine-bootstrap/ — keep these two
# values in sync, otherwise the engine starts cold after a restart.
BOT_ENGINE_SERVICE_URL_DEFAULT=http://127.0.0.1:3001
# Lifecycle commands (START/STOP/FORCE-CLOSE) may run loadMarkets and
# margin/leverage setup on the engine side, so they need a longer budget.
SERVICE_LIFECYCLE_TIMEOUT_SECONDS=30
# SYNC operations are in-memory only on the engine side: configuration edits
# while a bot is running. Keep this short so cosmetic PATCHes do not block
# Django workers.
SERVICE_SYNC_TIMEOUT_SECONDS=5
# Fallback used by the standalone trader runtime info client only.
SERVICE_REQUEST_TIMEOUT_SECONDS=30
SERVICE_REQUEST_RETRIES=3
SERVICE_REQUEST_RETRY_DELAY_SECONDS=1
