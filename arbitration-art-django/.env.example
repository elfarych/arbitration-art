# Django
SECRET_KEY=your-secret-key-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (default: SQLite)
# DATABASE_URL=postgres://user:password@localhost:5432/arbitration_art

# Internationalization
LANGUAGE_CODE=ru
TIME_ZONE=Asia/Almaty

# CORS (production only)
# CORS_ALLOWED_ORIGINS=https://your-frontend-domain.com

# Security (production only)
# SECURE_SSL_REDIRECT=True

# Service-to-service auth / control plane
SERVICE_SHARED_TOKEN=change-me-service-token
BOT_ENGINE_SERVICE_URL_DEFAULT=http://127.0.0.1:3001
# Lifecycle commands (START/STOP/FORCE-CLOSE) may run loadMarkets and
# margin/leverage setup on the engine side, so they need a longer budget.
SERVICE_LIFECYCLE_TIMEOUT_SECONDS=30
# SYNC operations are in-memory only on the engine side: configuration edits
# while a bot is running. Keep this short so cosmetic PATCHes do not block
# Django workers.
SERVICE_SYNC_TIMEOUT_SECONDS=5
# Fallback used by the standalone trader runtime info client only.
SERVICE_REQUEST_TIMEOUT_SECONDS=30
SERVICE_REQUEST_RETRIES=3
SERVICE_REQUEST_RETRY_DELAY_SECONDS=1
