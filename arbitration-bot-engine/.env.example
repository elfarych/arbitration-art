# =============================================================================
# arbitration-bot-engine — template
# Copy to .env and fill in the values.
# =============================================================================

# Public HTTP port for Django -> engine lifecycle requests.
PORT=3001

# Django REST API base URL. The engine writes trades back to this host.
DJANGO_API_URL=http://127.0.0.1:8000/api

# Self-identification URL the engine sends to Django on startup to fetch the
# list of active bots it should restore (GET /api/bots/engine-bootstrap/).
# Must match BotConfig.service_url exactly — otherwise Django returns an empty
# list and the engine starts with no traders. Defaults to http://127.0.0.1:PORT
# when unset; override per host for multi-engine deployments.
ENGINE_SERVICE_URL=http://127.0.0.1:3001

# Required. Must match SERVICE_SHARED_TOKEN in arbitration-art-django/.env.
# Generate with: openssl rand -hex 32
SERVICE_SHARED_TOKEN=change-me-service-token

# "true" enables exchange testnet endpoints (Binance, Bybit, Gate). MEXC
# contract API has no public testnet, so this flag is a no-op for MEXC. Keep
# "false" for real-money setups.
USE_TESTNET=false

# Fallback notional (USDT) when a BotConfig has no coin_amount.
TRADE_AMOUNT_USDT=50

# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO

# Maximum age (ms) of an OrderBook snapshot accepted for a non-emergency
# trading decision. Entry/profit signals are skipped while either leg's WS
# is more than this many ms behind. Emergency exits ignore this guard.
ORDERBOOK_MAX_AGE_MS=15000

# Maximum allowed difference (ms) between the local arrival timestamps of the
# primary and secondary snapshots used together. Protects against false
# spread signals when one leg's WS is lagging the other. Set to 0 to disable
# the cross-leg skew check while keeping max-age.
ORDERBOOK_MAX_SKEW_MS=20000
