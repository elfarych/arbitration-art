# =============================================================================
# arbitration-bot-engine — template
# Copy to .env and fill in the values.
# =============================================================================

# Public HTTP port for Django -> engine lifecycle requests.
PORT=3001

# Django REST API base URL. The engine writes trades back to this host.
DJANGO_API_URL=http://127.0.0.1:8000/api

# Required. Must match SERVICE_SHARED_TOKEN in arbitration-art-django/.env.
# Generate with: openssl rand -hex 32
SERVICE_SHARED_TOKEN=change-me-service-token

# "true" enables exchange testnet endpoints (Binance, Bybit). Keep "false" for
# real-money setups.
USE_TESTNET=false

# Fallback notional (USDT) when a BotConfig has no coin_amount.
TRADE_AMOUNT_USDT=50

# DEBUG | INFO | WARN | ERROR
LOG_LEVEL=INFO
