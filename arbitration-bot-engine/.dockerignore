# Local build artifacts and deps — rebuilt inside the image.
node_modules/
dist/
.tsbuildinfo
*.tsbuildinfo

# Env files (never bake secrets into images).
.env
*.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Tooling / IDE
.git/
.gitignore
.gitattributes
.github/
.idea/
.vscode/
.DS_Store

# Docs not needed at runtime.
DOCS.md
README.md
