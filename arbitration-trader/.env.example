# Django API endpoint
DJANGO_API_URL=http://127.0.0.1:8000/api

# === Exchange API credentials ===
BINANCE_API_KEY=
BINANCE_SECRET=

BYBIT_API_KEY=
BYBIT_SECRET=

# === Testnet mode ===
# Set to "true" to use Binance/Bybit testnet endpoints
USE_TESTNET=false

# === Trading parameters ===
# Position size in USDT (before leverage)
TRADE_AMOUNT_USDT=50

# Leverage (identical for both exchanges)
LEVERAGE=10

# Maximum concurrent open trades
MAX_CONCURRENT_TRADES=3

# Maximum trade duration in minutes (force-close after this)
MAX_TRADE_DURATION_MINUTES=60

# Max individual leg drawdown in percent before emergency close (Liquidation Protection)
MAX_LEG_DRAWDOWN_PERCENT=80

# === Monitoring parameters (spread detection) ===
# Spread growth threshold to open a trade (%)
OPEN_THRESHOLD=2.0

# True PnL threshold to close a trade (%)
CLOSE_THRESHOLD=1.5

# Orderbook depth limit (Bybit accepts: 1, 50, 200, 1000)
ORDERBOOK_LIMIT=50

# Number of pairs per Trader chunk
CHUNK_SIZE=10
